{
    "manifest_version": 3,
    "name": "Dislike Count for LeetCode",
    "description": "Restores the hidden dislike count on LeetCode.",
    "homepage_url": "https://github.com/nex-54/Dislike-Count-For-LeetCode",
    "version": "1.4.0",
    "minimum_chrome_version": "111",
    "browser_specific_settings": {
        "gecko": {
            "id": "dislike-count-for-leetcode@nex-54.github.io",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "icons": {
        "16": "icons/16.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
    },
    "permissions": [
        "storage"
    ],
    "action": {
        "default_icon": {
            "16": "icons/16.png",
            "48": "icons/48.png",
            "128": "icons/128.png"
        },
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "js": [
                "content.js"
            ],
            "matches": [
                "https://leetcode.com/*"
            ]
        },
        {
            "js": [
                "inject.js"
            ],
            "matches": [
                "https://leetcode.com/*"
            ],
            "world": "MAIN"
        }
    ]
}